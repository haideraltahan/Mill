{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mill",
  "description": "Unified multi-modal evaluation framework for text, image, video, and audio benchmarks.",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "docs/introduction",
          "docs/quickstart",
          "docs/installation",
          "docs/changelog"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "docs/guides/text-evaluation",
          "docs/guides/vision-evaluation",
          "docs/guides/distributed"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "docs/reference/cli",
          "docs/reference/tasks",
          "docs/reference/models",
          "docs/reference/output-types"
        ]
      },
      {
        "group": "Reproducibility",
        "pages": [
          "docs/reproducibility/overview",
          {
            "group": "Text",
            "pages": [
              "docs/reproducibility/mmlu",
              "docs/reproducibility/mmlu-pro"
            ]
          },
          {
            "group": "Vision",
            "pages": [
              "docs/reproducibility/cifar10",
              "docs/reproducibility/imagenet",
              "docs/reproducibility/mmmu_pro"
            ]
          },
          {
            "group": "Audio",
            "pages": [
              "docs/reproducibility/clotho_aqa",
              "docs/reproducibility/esc50"
            ]
          }
        ]
      },
      {
        "group": "Contributing",
        "pages": [
          "docs/contributing/add-a-benchmark",
          "docs/contributing/add-a-model"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/haideraltahan/Mill"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/haideraltahan/Mill"
    }
  }
}
